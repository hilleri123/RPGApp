# Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env

# --- Frontend (web-client) ---
# Dev (через прокси Next): /api
# Prod: полный URL API
NEXT_PUBLIC_API_URL=https://rpgzona.ru/api

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rpg_sessions

# --- Backend / auth ---
SECRET_KEY=change-me-long-random-string

# --- Telegram ---
# Токен @BotFather; нужен app (WebApp HMAC) и telegram-bot
BOT_TOKEN=

# Публичный URL сайта для magic-link из бота (/link, лобби).
# Не путать с NEXT_PUBLIC_API_URL — это фронт без /api.
# Dev: http://localhost:6602
# Prod: https://rpgzona.ru
WEB_CLIENT_URL=https://rpgzona.ru

# --- RabbitMQ (бот ↔ API, дальше — нейронки) ---
RABBIT_URL=amqp://rpg:rpg@rabbitmq:5672/
RABBITMQ_DEFAULT_USER=rpg
RABBITMQ_DEFAULT_PASS=rpg
